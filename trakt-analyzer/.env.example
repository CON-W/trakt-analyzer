# Trakt.tv API 配置
# 1. 前往 https://trakt.tv/oauth/applications 创建应用
# 2. 填写 Name 和 Description
# 3. 保存后获取 CLIENT_ID 和 CLIENT_SECRET

TRAKT_CLIENT_ID=your_trakt_client_id
TRAKT_CLIENT_SECRET=your_trakt_client_secret

# Trakt OAuth 回调地址
# 开发环境: http://localhost:5173/auth/callback
# 生产环境: http://你的服务器IP/auth/callback (或你的域名/auth/callback)
# 注意: 这个地址必须和 Trakt 应用设置中的 Redirect URI 完全一致
TRAKT_REDIRECT_URI=http://localhost:5173/auth/callback

# 服务器端口 (默认 3001)
PORT=3001


# TMDB API 配置 (可选，用于获取中文标题和海报)
# 1. 前往 https://www.themoviedb.org/settings/api 申请 API Key
# 2. 获取 API Key (v3 auth)
TMDB_API_KEY=your_tmdb_api_key
TMDB_LANGUAGE=zh-CN

# TMDB API 地址 (默认 https://api.themoviedb.org/3)
# 如果在中国无法访问 api.themoviedb.org，可以使用镜像:
# https://api.tmdb.org/3 (不带 the 的镜像)
TMDB_API_URL=https://api.tmdb.org/3

# TMDB 图片地址 (默认 https://image.tmdb.org/t/p)
# 如果在中国无法访问 image.tmdb.org，可以使用镜像:
# https://img.tmdb.org/t/p
TMDB_IMG_URL=https://image.tmdb.org/t/p
